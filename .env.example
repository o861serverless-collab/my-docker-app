# =================================================================
#  DOMAIN & EMAIL
# =================================================================
# Domain chính của bạn (không có http:// hoặc dấu /)
# Ví dụ: example.com
DOMAIN=yourdomain.com

# Hostname public của app chính.
# Mặc định repo dùng app.yourdomain.com, nhưng bạn có thể đặt root domain.
APP_HOST=app.yourdomain.com

# Email để Caddy đăng ký SSL certificate qua Let's Encrypt
CADDY_EMAIL=admin@yourdomain.com

# =================================================================
#  CADDY BASIC AUTH
# =================================================================
# Tên đăng nhập — dùng chung cho tất cả các dịch vụ được bảo vệ
# (app, dozzle, filebrowser). Portainer có auth riêng.
CADDY_AUTH_USER=admin

# Bcrypt hash của mật khẩu
# Cách tạo hash:
#   docker run --rm caddy:alpine caddy hash-password --plaintext "matkhauCuaBan"
# Lưu ý: trong Docker Compose, cần escape ký tự $ thành $$ để giữ nguyên bcrypt hash.
CADDY_AUTH_HASH=$$2a$$14$$Zkx19XLiW6VYouLHR5NmfOFU0z2GTNmpkT/5qqR7hx4IjWJPDhjvG

# =================================================================
#  CLOUDFLARE TUNNEL
# =================================================================
# Token của Cloudflare Tunnel để expose dịch vụ ra Internet
# Cách lấy:
#   1. Vào https://one.dash.cloudflare.com/
#   2. Zero Trust → Networks → Tunnels → Create a tunnel
#   3. Chọn "Cloudflared" → copy token
CF_TUNNEL_TOKEN=your_cloudflare_tunnel_token_here

# =================================================================
#  TAILSCALE (tuỳ chọn — cho team nội bộ)
# =================================================================
# Auth key để Tailscale tự động kết nối
# Cách lấy:
#   https://login.tailscale.com/admin/settings/keys → Generate auth key
#   Nên tích "Reusable" và "Ephemeral" cho server
TS_AUTHKEY=tskey-auth-xxxxxxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# =================================================================
#  NODE.JS APP
# =================================================================
# Port app Node.js lắng nghe bên trong container
APP_PORT=3000

# Môi trường chạy: production | development
NODE_ENV=production

# Đường dẫn thư mục log bên trong container (không cần đổi)
LOG_DIR=/app/logs

# =================================================================
#  PORTAINER — Quản lý Docker qua UI
# =================================================================
# Subdomain truy cập Portainer
# Ví dụ: portainer.yourdomain.com
PORTAINER_SUBDOMAIN=portainer

# =================================================================
#  DOZZLE — Xem log container realtime
# =================================================================
# Subdomain truy cập Dozzle
DOZZLE_SUBDOMAIN=logs

# =================================================================
#  FILEBROWSER — Duyệt file log qua web
# =================================================================
# Subdomain truy cập Filebrowser
FILEBROWSER_SUBDOMAIN=files
